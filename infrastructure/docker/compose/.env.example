# Database credentials
POSTGRES_USER=helix
POSTGRES_PASSWORD=change_me_in_dot_env
POSTGRES_DB=helixterminator

# Grafana admin password
GF_SECURITY_ADMIN_PASSWORD=change_me_in_dot_env

# Redis (no auth by default in this compose setup)

# Kafka configuration
KAFKA_BROKERS=kafka:9092

# JWT signing keys — auth-service (private+public), gateway-service +
# billing-service (public only). Leave BOTH unset for local dev bring-up:
# auth-service falls back to a loud-warned ephemeral per-process keypair
# (fine for solo local dev, tokens won't validate across restarts or against
# gateway/billing). Populate both + set ENVIRONMENT=production below for a
# shared/staging compose deployment. NEVER commit a real key — see
# docs/guides/JWT_KEY_PROVISIONING.md for how to generate a keypair.
# ENVIRONMENT=production
# JWT_PRIVATE_KEY=<base64-ed25519-private-key -- see docs/guides/JWT_KEY_PROVISIONING.md>
# JWT_PUBLIC_KEY=<base64-ed25519-public-key -- see docs/guides/JWT_KEY_PROVISIONING.md>

# ─────────────────────────────────────────────────────────────────────────────
# Feature-tier credentials — placeholders ONLY (Constitution §11.4.10/§11.4.30)
# ─────────────────────────────────────────────────────────────────────────────
# NEVER commit real secrets. Every slot below is commented + REDACTED. Copy this
# file to the gitignored .env and fill the tiers you enable. Secret FILES (the
# FCM service-account JSON, the APNs .p8 key) are referenced BY PATH and live
# under scripts/testing/secrets/ (gitignored). Each tier's honest default when
# unset is documented in docs/credentials/FEATURE_TIER_SETUP.md.

# --- Billing tier: Stripe (billing-service) ---------------------------------
# STRIPE_SECRET_KEY present ARMS the payment gateway (no Stripe API call made at
# startup). Unset ⇒ gateway disabled (internal dev default).
# STRIPE_SECRET_KEY=<redacted -- sk_live_… / sk_test_… from the Stripe dashboard>
# STRIPE_WEBHOOK_SECRET=<redacted -- whsec_… ; enables webhook-signature verification readiness>

# --- Cloud LLM tier: OpenAI OR Anthropic (ai-service) -----------------------
# Set ONE key. OPENAI_API_KEY wins if both are set; else ANTHROPIC_API_KEY; else
# the local HelixLLM tier is used (honest default). AI_CLOUD_MODEL /
# AI_CLOUD_BASE_URL override the per-provider defaults (openai: gpt-4o-mini @
# https://api.openai.com/v1/chat/completions ; anthropic: claude-3-5-haiku-latest
# @ https://api.anthropic.com/v1/chat/completions — its OpenAI-compatible path).
# OPENAI_API_KEY=<redacted -- sk-… from platform.openai.com>
# ANTHROPIC_API_KEY=<redacted -- sk-ant-… from console.anthropic.com>
# AI_CLOUD_MODEL=<optional -- overrides the per-provider default model>
# AI_CLOUD_BASE_URL=<optional -- overrides the per-provider chat-completions URL>
# LLM_MONTHLY_COST_CEILING_USD=<optional -- non-negative number; SURFACED + logged, NOT enforced yet>

# --- Push tier: FCM or APNs (notification-service) --------------------------
# A COMPLETE set arms the push sender (still makes NO network call — the real
# FCM/APNs client is not yet built; see docs/credentials/FEATURE_TIER_SETUP.md).
# FCM: either the HTTP v1 service-account JSON PATH, or the legacy server key.
# FCM_SERVICE_ACCOUNT_JSON=scripts/testing/secrets/fcm_service_account.json
# FCM_SERVER_KEY=<redacted -- legacy FCM HTTP server key>
# APNs: ALL FOUR required together (.p8 key PATH + the three identifiers).
# APNS_KEY_PATH=scripts/testing/secrets/apns_auth_key.p8
# APNS_KEY_ID=<redacted -- 10-char APNs key id>
# APNS_TEAM_ID=<redacted -- 10-char Apple team id>
# APNS_BUNDLE_ID=<redacted -- e.g. com.helixdevelopment.helixterminator>

# --- SMTP tier: real email delivery (notification-service) ------------------
# SMTP_HOST present enables real email delivery (see delivery.SMTPConfigFromEnv);
# unset ⇒ email honestly reported as not configured. PLAIN auth is used only when
# SMTP_USERNAME is set (MailHog/Mailpit-class dev sinks need no auth).
# SMTP_HOST=<redacted -- e.g. smtp.example.com>
# SMTP_PORT=587
# SMTP_FROM=notifications@example.com
# SMTP_USERNAME=<redacted -- optional; PLAIN auth username>
# SMTP_PASSWORD=<redacted -- optional; PLAIN auth password>
