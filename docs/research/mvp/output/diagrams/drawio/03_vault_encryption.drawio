        <!-- ===== ZERO KNOWLEDGE NOTE ===== -->
        <mxCell id="zk-note" value="Zero-Knowledge Architecture:&#xa;• Server never sees plaintext data&#xa;• Master key derived client-side only&#xa;• All crypto operations in client memory&#xa;• Server stores only encrypted blobs&#xa;• PBKDF salt stored separately from ciphertext" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=20;fillColor=#fffde7;strokeColor=#d6b656;align=left;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="870" y="600" width="360" height="120" as="geometry" />
        </mxCell>

        <!-- ===== ENCRYPTION SPEC NOTE ===== -->
        <mxCell id="enc-note" value="Encryption Spec:&#xa;• Algorithm: AES-256-GCM&#xa;• AEAD Auth Tag: 128-bit&#xa;• Random IV: 96-bit (per item)&#xa;• MAC: HMAC-SHA256&#xa;• KDF: Argon2id (RFC 9106)" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=20;fillColor=#f8cecc;strokeColor=#b85450;align=left;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="600" width="300" height="120" as="geometry" />
        </mxCell>

        <!-- ===== DB SCHEMA ===== -->
        <mxCell id="db-schema" value="vault_items schema:&#xa;  id UUID PK&#xa;  vault_id UUID FK&#xa;  encrypted_data BYTEA&#xa;  iv BYTEA (96-bit)&#xa;  auth_tag BYTEA&#xa;  item_key_id UUID FK&#xa;  created_at TIMESTAMP" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=20;fillColor=#d5e8d4;strokeColor=#82b366;align=left;fontSize=11;" vertex="1" parent="1">
