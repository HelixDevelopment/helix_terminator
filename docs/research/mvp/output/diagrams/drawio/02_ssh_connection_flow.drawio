          <mxGeometry x="270" y="80" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p-auth" value="Auth Service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="80" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p-rbac" value="RBAC Service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="690" y="80" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p-sshproxy" value="SSH Proxy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="80" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p-pki" value="PKI Service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1110" y="80" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p-target" value="Target SSH&#xa;Server" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1320" y="80" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- Lifelines -->
        <mxCell id="ll-client" value="" style="endArrow=none;dashed=1;strokeColor=#9673a6;" edge="1" parent="1">
          <mxGeometry x="130" y="140" relative="1" as="geometry"><Array as="points"><mxPoint x="130" y="1080"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="ll-gateway" value="" style="endArrow=none;dashed=1;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry x="340" y="140" relative="1" as="geometry"><Array as="points"><mxPoint x="340" y="1080"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="ll-auth" value="" style="endArrow=none;dashed=1;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry x="550" y="140" relative="1" as="geometry"><Array as="points"><mxPoint x="550" y="1080"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="ll-rbac" value="" style="endArrow=none;dashed=1;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry x="760" y="140" relative="1" as="geometry"><Array as="points"><mxPoint x="760" y="1080"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="ll-sshproxy" value="" style="endArrow=none;dashed=1;strokeColor=#6c8ebf;" edge="1" parent="1">
          <mxGeometry x="970" y="140" relative="1" as="geometry"><Array as="points"><mxPoint x="970" y="1080"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="ll-pki" value="" style="endArrow=none;dashed=1;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry x="1180" y="140" relative="1" as="geometry"><Array as="points"><mxPoint x="1180" y="1080"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="ll-target" value="" style="endArrow=none;dashed=1;strokeColor=#666666;" edge="1" parent="1">
          <mxGeometry x="1390" y="140" relative="1" as="geometry"><Array as="points"><mxPoint x="1390" y="1080"/></Array></mxGeometry>
        </mxCell>

        <!-- ===== STEP 1: TLS Handshake ===== -->
        <mxCell id="step1-label" value="1. TLS Handshake" style="text;html=1;strokeColor=none;fillColor=#fffde7;align=left;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="155" width="150" height="20" as="geometry" />
        </mxCell>
        <mxCell id="s1-req" value="CONNECT (TLS 1.3)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#9673a6;fillColor=#9673a6;" edge="1" parent="1">
          <mxGeometry x="130" y="185" relative="1" as="geometry"><mxPoint x="130" y="185" as="sourcePoint"/><mxPoint x="340" y="185" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="s1-resp" value="TLS Certificate" style="edgeStyle=orthogonalEdgeStyle;rounded=0;dashed=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry x="340" y="205" relative="1" as="geometry"><mxPoint x="340" y="205" as="sourcePoint"/><mxPoint x="130" y="205" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ===== STEP 2: Authentication ===== -->
        <mxCell id="step2-label" value="2. User Authentication" style="text;html=1;strokeColor=none;fillColor=#ffe6cc;align=left;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="230" width="180" height="20" as="geometry" />
        </mxCell>
        <mxCell id="s2-req" value="POST /auth/login&#xa;{username, password}" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#9673a6;fillColor=#9673a6;" edge="1" parent="1">
          <mxGeometry x="130" y="260" relative="1" as="geometry"><mxPoint x="130" y="260" as="sourcePoint"/><mxPoint x="340" y="260" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="s2-fwd" value="Forward credentials" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#b85450;fillColor=#b85450;" edge="1" parent="1">
          <mxGeometry x="340" y="275" relative="1" as="geometry"><mxPoint x="340" y="275" as="sourcePoint"/><mxPoint x="550" y="275" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="s2-verify" value="Verify + MFA Check" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;dashed=1;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry x="550" y="290" relative="1" as="geometry"><mxPoint x="550" y="290" as="sourcePoint"/><mxPoint x="760" y="290" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="s2-mfa-resp" value="Permissions OK" style="edgeStyle=orthogonalEdgeStyle;rounded=0;dashed=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry x="760" y="310" relative="1" as="geometry"><mxPoint x="760" y="310" as="sourcePoint"/><mxPoint x="550" y="310" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="s2-jwt" value="JWT Access Token" style="edgeStyle=orthogonalEdgeStyle;rounded=0;dashed=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry x="550" y="330" relative="1" as="geometry"><mxPoint x="550" y="330" as="sourcePoint"/><mxPoint x="340" y="330" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="s2-token-client" value="JWT Token" style="edgeStyle=orthogonalEdgeStyle;rounded=0;dashed=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry x="340" y="345" relative="1" as="geometry"><mxPoint x="340" y="345" as="sourcePoint"/><mxPoint x="130" y="345" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ===== STEP 3: Session Request ===== -->
        <mxCell id="step3-label" value="3. SSH Session Request" style="text;html=1;strokeColor=none;fillColor=#dae8fc;align=left;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="370" width="190" height="20" as="geometry" />
        </mxCell>
        <mxCell id="s3-req" value="POST /sessions&#xa;{hostId, JWT}" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#9673a6;fillColor=#9673a6;" edge="1" parent="1">
          <mxGeometry x="130" y="400" relative="1" as="geometry"><mxPoint x="130" y="400" as="sourcePoint"/><mxPoint x="340" y="400" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="s3-validate" value="Validate JWT" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry x="340" y="415" relative="1" as="geometry"><mxPoint x="340" y="415" as="sourcePoint"/><mxPoint x="550" y="415" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="s3-check-perm" value="Check SSH permissions" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry x="550" y="430" relative="1" as="geometry"><mxPoint x="550" y="430" as="sourcePoint"/><mxPoint x="760" y="430" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="s3-perm-ok" value="Authorized" style="edgeStyle=orthogonalEdgeStyle;rounded=0;dashed=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry x="760" y="450" relative="1" as="geometry"><mxPoint x="760" y="450" as="sourcePoint"/><mxPoint x="550" y="450" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ===== STEP 4: Certificate Issuance ===== -->
        <mxCell id="step4-label" value="4. Certificate Issuance" style="text;html=1;strokeColor=none;fillColor=#f8cecc;align=left;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="470" width="190" height="20" as="geometry" />
        </mxCell>
        <mxCell id="s4-cert-req" value="Sign SSH Cert&#xa;(pubkey, principals)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry x="550" y="500" relative="1" as="geometry"><mxPoint x="550" y="500" as="sourcePoint"/><mxPoint x="1180" y="500" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="s4-cert-resp" value="Signed SSH Certificate (TTL=1h)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;dashed=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry x="1180" y="520" relative="1" as="geometry"><mxPoint x="1180" y="520" as="sourcePoint"/><mxPoint x="550" y="520" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="s4-route" value="Route to SSH Proxy" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6c8ebf;" edge="1" parent="1">
          <mxGeometry x="550" y="545" relative="1" as="geometry"><mxPoint x="550" y="545" as="sourcePoint"/><mxPoint x="970" y="545" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ===== STEP 5: SSH Proxy Connection ===== -->
        <mxCell id="step5-label" value="5. SSH Proxy to Target" style="text;html=1;strokeColor=none;fillColor=#dae8fc;align=left;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="565" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="s5-connect" value="SSH Connect&#xa;(with signed cert)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6c8ebf;fillColor=#6c8ebf;" edge="1" parent="1">
          <mxGeometry x="970" y="595" relative="1" as="geometry"><mxPoint x="970" y="595" as="sourcePoint"/><mxPoint x="1390" y="595" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="s5-verify" value="Verify CA Signature" style="edgeStyle=orthogonalEdgeStyle;rounded=0;dashed=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#666666;" edge="1" parent="1">
          <mxGeometry x="1390" y="615" relative="1" as="geometry"><mxPoint x="1390" y="615" as="sourcePoint"/><mxPoint x="970" y="615" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="s5-accepted" value="Connection Accepted" style="edgeStyle=orthogonalEdgeStyle;rounded=0;dashed=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#6c8ebf;" edge="1" parent="1">
          <mxGeometry x="1390" y="635" relative="1" as="geometry"><mxPoint x="1390" y="635" as="sourcePoint"/><mxPoint x="970" y="635" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ===== STEP 6: WebSocket tunnel ===== -->
        <mxCell id="step6-label" value="6. WebSocket Tunnel Established" style="text;html=1;strokeColor=none;fillColor=#d5e8d4;align=left;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="660" width="250" height="20" as="geometry" />
        </mxCell>
        <mxCell id="s6-ws" value="WebSocket /sessions/{id}/terminal" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#82b366;fillColor=#82b366;" edge="1" parent="1">
          <mxGeometry x="130" y="690" relative="1" as="geometry"><mxPoint x="130" y="690" as="sourcePoint"/><mxPoint x="970" y="690" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="s6-pty" value="PTY Allocated" style="edgeStyle=orthogonalEdgeStyle;rounded=0;dashed=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#82b366;" edge="1" parent="1">
          <mxGeometry x="970" y="710" relative="1" as="geometry"><mxPoint x="970" y="710" as="sourcePoint"/><mxPoint x="130" y="710" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ===== STEP 7: Data Flow ===== -->
        <mxCell id="step7-label" value="7. Bidirectional Terminal Data" style="text;html=1;strokeColor=none;fillColor=#d5e8d4;align=left;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="730" width="250" height="20" as="geometry" />
        </mxCell>
        <mxCell id="s7-data" value="Terminal Input → Proxy → Target" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#9673a6;" edge="1" parent="1">
          <mxGeometry x="130" y="760" relative="1" as="geometry"><mxPoint x="130" y="760" as="sourcePoint"/><mxPoint x="1390" y="760" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="s7-out" value="Terminal Output → Proxy → Client" style="edgeStyle=orthogonalEdgeStyle;rounded=0;dashed=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#9673a6;" edge="1" parent="1">
          <mxGeometry x="1390" y="780" relative="1" as="geometry"><mxPoint x="1390" y="780" as="sourcePoint"/><mxPoint x="130" y="780" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ===== STEP 8: Audit ===== -->
        <mxCell id="step8-label" value="8. Audit &amp; Recording" style="text;html=1;strokeColor=none;fillColor=#fff2cc;align=left;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="800" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="s8-audit" value="Publish session.events to Kafka" style="edgeStyle=orthogonalEdgeStyle;rounded=0;dashed=1;strokeColor=#d6b656;" edge="1" parent="1">
          <mxGeometry x="970" y="825" relative="1" as="geometry"><mxPoint x="970" y="825" as="sourcePoint"/><mxPoint x="550" y="825" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="s8-record" value="Store recording to S3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;dashed=1;strokeColor=#d6b656;" edge="1" parent="1">
          <mxGeometry x="970" y="845" relative="1" as="geometry"><mxPoint x="970" y="845" as="sourcePoint"/><mxPoint x="340" y="845" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ===== STEP 9: Disconnect ===== -->
        <mxCell id="step9-label" value="9. Session Disconnect" style="text;html=1;strokeColor=none;fillColor=#f5f5f5;align=left;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="870" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="s9-close" value="DISCONNECT" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#9673a6;" edge="1" parent="1">
          <mxGeometry x="130" y="900" relative="1" as="geometry"><mxPoint x="130" y="900" as="sourcePoint"/><mxPoint x="1390" y="900" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="s9-cleanup" value="Revoke cert, close session, finalize audit" style="edgeStyle=orthogonalEdgeStyle;rounded=0;dashed=1;strokeColor=#666666;" edge="1" parent="1">
          <mxGeometry x="970" y="925" relative="1" as="geometry"><mxPoint x="970" y="925" as="sourcePoint"/><mxPoint x="550" y="925" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Step boxes on the left for reference -->
        <mxCell id="note1" value="Note: All service-to-service&#xa;communication uses mTLS.&#xa;JWT TTL = 15min.&#xa;SSH Cert TTL = 1h." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=20;fillColor=#fffde7;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="20" y="940" width="200" height="80" as="geometry" />
        </mxCell>

