    classDef topic fill:#f57f17,stroke:#e65100,color:#000
    classDef consumer fill:#2e7d32,stroke:#1b5e20,color:#fff

    subgraph Producers["Kafka Producers"]
        P_SSH["SSH Proxy Service"]
